{
  "name": "smartreceipt---ai-expense-tracker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build:backend",
    "build:backend": "cd backend && npm install && npm run build",
    "preview": "vite preview",
    "vercel-build": "npm run build",
    "pretest": "node scripts/pre-test-build.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
