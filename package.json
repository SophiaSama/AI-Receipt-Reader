    "test:e2e": "vitest run tests/e2e",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "recharts": "^3.6.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vercel/node": "^3.2.26",
    "@vitest/ui": "^2.1.8",
    "autoprefixer": "^10.4.20",
    "node-fetch": "^3.3.2",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^2.1.8"
  }
}