{
    "version": 2,
    "builds": [
        {
            "src": "package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        },
        {
            "src": "backend/dist/local/server.js",
            "use": "@vercel/node",
            "config": {
                "runtime": "nodejs20.x"
            }
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/backend/dist/local/server.js"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}