# Environment variables for E2E tests

# Application URLs
BASE_URL=http://localhost:3000
API_URL=http://localhost:3000/api

# Optional API forwarding
# By default, the app is expected to serve API routes under BASE_URL/api.
# If you run the backend separately (e.g. on port 3001), you can forward
# all browser /api/* calls to that backend origin.
FORWARD_API_TO_BACKEND=false
BACKEND_ORIGIN=http://localhost:3001

# Browser settings
HEADLESS=false
SLOW_MO=0
RECORD_VIDEO=false

# Test user credentials (if authentication is implemented)
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=testpassword123

# Test data
TEST_RECEIPT_IMAGE=fixtures/sample-receipt.png

# Timeouts (milliseconds)
DEFAULT_TIMEOUT=30000
NAVIGATION_TIMEOUT=30000

# Debugging
DEBUG=false
TRACE=false
