{
    "name": "smart-receipt-backend",
    "version": "1.0.0",
    "engines": {
        "node": ">=20.0.0",
        "npm": ">=10.0.0"
    },
    "description": "Serverless backend for SmartReceiptReader with AI integration",
    "main": "dist/local/server.js",
    "scripts": {
        "build": "tsc",
        "dev": "ts-node local/server.ts",
        "deploy": "sam build && sam deploy --guided",
        "start": "node dist/local/server.js"
    },
    "dependencies": {
        "@aws-sdk/client-dynamodb": "^3.540.0",
        "@aws-sdk/client-s3": "^3.540.0",
        "@aws-sdk/client-sts": "^3.540.0",
        "@aws-sdk/lib-dynamodb": "^3.540.0",
        "@mistralai/mistralai": "^1.0.0",
        "busboy": "^1.6.0",
        "cors": "^2.8.5",
        "dotenv": "^17.2.3",
        "express": "^4.18.2",
        "multer": "^1.4.5-lts.1",
        "uuid": "^9.0.0"
    },
    "devDependencies": {
        "@types/busboy": "^1.5.3",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/multer": "^1.4.11",
        "@types/node": "^20.11.0",
        "@types/uuid": "^9.0.8",
        "ts-node": "^10.9.2",
        "typescript": "^5.3.3"
    }
}
