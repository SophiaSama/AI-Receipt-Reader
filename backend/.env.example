# Mistral AI API Key (required for OCR and LLM processing)
MISTRAL_API_KEY=your_mistral_api_key_here

# OpenRouter API Key (required for non-Mistral models)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenRouter configuration (optional)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=http://localhost:3000
OPENROUTER_APP_NAME=SmartReceiptReader

# AWS Configuration
AWS_REGION=us-east-1
S3_BUCKET_NAME=smart-receipt-images
DYNAMODB_TABLE_NAME=smart-receipts

# Authentication Method (choose one)
# Method 1: Static Access Keys (simpler)
# AWS_ACCESS_KEY_ID=your_access_key_id
# AWS_SECRET_ACCESS_KEY=your_secret_access_key

# Method 2: IAM Roles with STS (more secure, for production)
# USE_IAM_ROLE=true
# AWS_ROLE_ARN=arn:aws:iam::123456789012:role/VercelSmartReceiptRole
# AWS_EXTERNAL_ID=your_external_id_here

# Local Development (set to 'true' to use in-memory storage instead of AWS)
USE_LOCAL_STORAGE=true

# Server Configuration
PORT=3001
