# Mistral AI API Key (required for OCR and LLM processing)
MISTRAL_API_KEY=your_mistral_api_key_here

# AWS Configuration
AWS_REGION=us-east-1
S3_BUCKET_NAME=smart-receipt-images
DYNAMODB_TABLE_NAME=smart-receipts

# Local Development (set to 'true' to use in-memory storage instead of AWS)
USE_LOCAL_STORAGE=true

# Server Configuration
PORT=3001
